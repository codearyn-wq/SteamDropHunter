# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_id_here

# Server Configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# Render Configuration
RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# Polling Configuration (in milliseconds, default: 5 minutes)
POLL_INTERVAL_MS=300000

# Keep-Alive Configuration (in milliseconds, default: 4 minutes)
KEEP_ALIVE_INTERVAL_MS=240000

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info

# Database Path
DATABASE_PATH=./data/steam_drop_hunter.db

# Redis Configuration (optional, uses in-memory if not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API Key for manual trigger endpoint
API_KEY=your_secure_api_key_here
