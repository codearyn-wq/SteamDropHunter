{
  "name": "steam-drop-hunter",
  "version": "1.0.0",
  "description": "24/7 bot that monitors Steam for temporarily free paid games",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "docker:build": "docker build -t steam-drop-hunter .",
    "docker:run": "docker-compose up -d",
    "render:start": "node dist/index.js",
    "postinstall": "node -e \"console.log('Steam Drop Hunter installed successfully!')\""
  },
  "keywords": [
    "steam",
    "free-games",
    "bot",
    "telegram",
    "monitor"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.1",
    "@types/sql.js": "^1.4.9",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.64.0",
    "sql.js": "^1.10.3",
    "typescript": "^5.3.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
